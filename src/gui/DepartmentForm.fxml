<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="220.0" prefWidth="519.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.DepartmentFormController">
   <children>
      <GridPane layoutX="28.0" layoutY="28.0" prefHeight="75.0" prefWidth="434.0"
                AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" prefWidth="64.0" />
          <ColumnConstraints hgrow="SOMETIMES" prefWidth="175.8" />
          <ColumnConstraints hgrow="SOMETIMES" prefWidth="180.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints prefHeight="32.0" vgrow="SOMETIMES" />
          <RowConstraints prefHeight="28.8" vgrow="SOMETIMES" />
          <RowConstraints prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Id" />
            <Label text="Name" GridPane.rowIndex="1" />
            <TextField fx:id="txtId" editable="false" GridPane.columnIndex="1" />
            <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label fx:id="labelErrorName" textFill="#ea1616" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <HBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
               <children>
                  <Button fx:id="btSave" text="Save" onAction="#onBtSaveAction">
                     <HBox.margin>
                        <Insets top="6.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="btCancel" text="Cancel" onAction="#onBtCancelAction">
                     <HBox.margin>
                        <Insets top="6.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </GridPane>
   </children>
</AnchorPane>


